{
  "name": "functions",
  "description": "Cloud Functions for Firebase",
  "private": true,
  "main": "index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
